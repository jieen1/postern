(invariant DB_BASE_FIELDS_REQUIRED
  (severity error)
  (description "policy.db 每张业务表必须声明统一基础字段:id,version,created_at,created_by,updated_at,updated_by,delete_flag,enable_flag")
  (category db-layer)
  (rationale "统一基础字段是乐观锁、操作归属审计与逻辑删除的地基;缺失字段的表会静默逃逸全部数据库层保障")
  (assert (eq (path db_layer base_fields violation_count) 0)))
(invariant DB_BASE_FIELDS_TEETH
  (severity error)
  (description "反例自检:基础字段扫描器必须能在内嵌反例(缺失 version 等字段的表定义)上检出违规")
  (category db-layer)
  (rationale "确保 DB_BASE_FIELDS_REQUIRED 真实生效:扫描器若检不出已知违规反例,说明规则空转,本契约立即失败")
  (assert (gte (path db_layer base_fields selftest_violation_count) 1)))
(invariant DB_WRITE_PATH_CENTRALIZED
  (severity error)
  (description "INSERT/UPDATE 语句只允许出现在 postern-store 的统一基础仓储模块,由其自动填充 version/created_at/created_by/updated_at/updated_by 并执行乐观锁(version 比对+自增)")
  (category db-layer)
  (rationale "审计字段自动化的前提是写路径唯一:任何绕过基础仓储的散落写语句都会破坏字段自动填充与乐观锁")
  (assert (eq (path db_layer write_path violation_count) 0)))
(invariant DB_WRITE_PATH_TEETH
  (severity error)
  (description "反例自检:写路径扫描器必须能在内嵌反例(基础仓储模块之外的 INSERT 语句)上检出违规")
  (category db-layer)
  (rationale "确保 DB_WRITE_PATH_CENTRALIZED 真实生效")
  (assert (gte (path db_layer write_path selftest_violation_count) 1)))
(invariant DB_LOGICAL_DELETE_ONLY
  (severity error)
  (description "工作区内禁止任何针对 policy.db 的 DELETE 语句;删除一律为逻辑删除(UPDATE delete_flag=1),不存在物理删除接口")
  (category db-layer)
  (rationale "物理删除不可逆且摧毁审计链;逻辑删除保证数据可追溯,删除行为本身可归属(updated_by)")
  (assert (eq (path db_layer logical_delete violation_count) 0)))
(invariant DB_LOGICAL_DELETE_TEETH
  (severity error)
  (description "反例自检:逻辑删除扫描器必须能在内嵌反例(DELETE FROM 语句)上检出违规")
  (category db-layer)
  (rationale "确保 DB_LOGICAL_DELETE_ONLY 真实生效")
  (assert (gte (path db_layer logical_delete selftest_violation_count) 1)))
(invariant DB_DEFAULT_SCOPE_EXCLUDES_DELETED
  (severity error)
  (description "postern-store 中每条 SELECT 必须经统一作用域构建器或显式携带 delete_flag 过滤;默认查询永不返回已逻辑删除数据")
  (category db-layer)
  (rationale "逻辑删除若不配合默认过滤,已删数据会泄漏进业务查询,等同未删除")
  (assert (eq (path db_layer default_scope violation_count) 0)))
(invariant DB_DEFAULT_SCOPE_TEETH
  (severity error)
  (description "反例自检:默认作用域扫描器必须能在内嵌反例(无 delete_flag 过滤的 SELECT)上检出违规")
  (category db-layer)
  (rationale "确保 DB_DEFAULT_SCOPE_EXCLUDES_DELETED 真实生效")
  (assert (gte (path db_layer default_scope selftest_violation_count) 1)))
(invariant DB_NO_RAW_SQL_OUTSIDE_STORE
  (severity error)
  (description "SQL 字符串与 rusqlite 依赖只允许出现在 postern-store crate;例外必须事先登记于受保护的 contract/sql-exceptions.json(写明目的,经人工审批)")
  (category db-layer)
  (rationale "SQL 散落各处会绕过基础字段自动化、默认作用域与分页约束;例外登记文件位于受保护路径,修改即走人工审批流程,'申请'由系统强制而非约定")
  (assert (eq (path db_layer raw_sql violation_count) 0)))
(invariant DB_RAW_SQL_TEETH
  (severity error)
  (description "反例自检:裸 SQL 扫描器必须能在内嵌反例(store 之外 crate 中的 SELECT 字符串)上检出违规")
  (category db-layer)
  (rationale "确保 DB_NO_RAW_SQL_OUTSIDE_STORE 真实生效")
  (assert (gte (path db_layer raw_sql selftest_violation_count) 1)))
(invariant DB_PAGINATION_MANDATORY
  (severity error)
  (description "所有集合查询必须经统一分页工具:store 集合查询函数必须接收 PageQuery,SELECT 必须 LIMIT 封顶,每页条数钳制到全局上限;对外查询接口必须携带分页参数,禁止无界查询与前端分页")
  (category db-layer)
  (rationale "无界集合查询是性能与内存事故源,前端分页等于把全量数据交给客户端;分页必须后端执行且系统强制")
  (assert (eq (path db_layer pagination violation_count) 0)))
(invariant DB_PAGINATION_TEETH
  (severity error)
  (description "反例自检:分页扫描器必须能在内嵌反例(无 LIMIT 的集合 SELECT)上检出违规")
  (category db-layer)
  (rationale "确保 DB_PAGINATION_MANDATORY 真实生效")
  (assert (gte (path db_layer pagination selftest_violation_count) 1)))
(invariant DB_UNIFIED_ID_GENERATOR
  (severity error)
  (description "全部主键 id 由 postern-core 的统一雪花生成器(IdGen)产生;工作区依赖禁止引入 uuid/ulid/nanoid 等替代 id 库")
  (category db-layer)
  (rationale "id 生成分裂会破坏全局有序性与唯一性假设;封禁替代库使统一生成器成为唯一可能的来源")
  (assert (eq (path db_layer id_generator violation_count) 0)))
(invariant DB_ID_GENERATOR_TEETH
  (severity error)
  (description "反例自检:id 生成器扫描器必须能在内嵌反例(Cargo.toml 中的 uuid 依赖声明)上检出违规")
  (category db-layer)
  (rationale "确保 DB_UNIFIED_ID_GENERATOR 真实生效")
  (assert (gte (path db_layer id_generator selftest_violation_count) 1)))
(invariant SEC_ADMIN_NOT_GRANTABLE
  (severity error)
  (description "Capability 枚举不得含 Admin 变体,且 roles 表必须带禁止 admin 角色名的 CHECK 约束")
  (category security-core)
  (rationale "admin 是权限的权限,模型层硬约束不可授予任何 Principal(公理三);类型层无 Admin 变体 + schema 层 CHECK 双保险")
  (assert (eq (path db_layer admin_not_grantable violation_count) 0)))
(invariant SEC_ADMIN_NOT_GRANTABLE_TEETH
  (severity error)
  (description "反例自检:admin 扫描器须在含 Admin 变体的枚举或缺 CHECK 的 roles 表上检出违规")
  (category security-core)
  (rationale "确保 SEC_ADMIN_NOT_GRANTABLE 真实生效")
  (assert (gte (path db_layer admin_not_grantable selftest_violation_count) 1)))
(invariant SEC_SECRET_TYPE_DISCIPLINE
  (severity error)
  (description "ResolvedTarget 与 ResourceCredential 不得 derive Clone 或 Serialize")
  (category security-core)
  (rationale "机密类型(真实地址/资源凭据)不可复制不可序列化,是公理四凭据零接触的编译期表达")
  (assert (eq (path db_layer secret_type_discipline violation_count) 0)))
(invariant SEC_SECRET_TYPE_DISCIPLINE_TEETH
  (severity error)
  (description "反例自检:机密类型 derive 扫描器须在 derive(Clone) 的 ResolvedTarget 上检出违规")
  (category security-core)
  (rationale "确保 SEC_SECRET_TYPE_DISCIPLINE 真实生效")
  (assert (gte (path db_layer secret_type_discipline selftest_violation_count) 1)))
(invariant SEC_CONSTRUCTION_SITES
  (severity error)
  (description "ConnOrigin 只能在 daemon shells(listener)构造;ResolvedTarget/ResourceCredential 只能在 postern-secrets 构造")
  (category security-core)
  (rationale "来源采集与机密构造的唯一合法位置由编译边界固定:外壳采集来源不采信自报(公理三),机密只诞生于机密面(公理四)")
  (assert (eq (path db_layer construction_sites violation_count) 0)))
(invariant SEC_CONSTRUCTION_SITES_TEETH
  (severity error)
  (description "反例自检:构造点扫描器须在非法位置构造 ResolvedTarget 或 ConnOrigin 时检出违规")
  (category security-core)
  (rationale "确保 SEC_CONSTRUCTION_SITES 真实生效")
  (assert (gte (path db_layer construction_sites selftest_violation_count) 1)))
(invariant ARCH_FORBIDDEN_EDGES
  (severity error)
  (description "工作区依赖图不得出现禁止边:adapters→secrets/transports/store、transports→store、cli→store/secrets、core→任何 IO crate")
  (category security-core)
  (rationale "数据面无路径触达机密/策略是编译期事实而非约定(公理三);依赖图即架构图")
  (assert (eq (path db_layer forbidden_edges violation_count) 0)))
(invariant ARCH_FORBIDDEN_EDGES_TEETH
  (severity error)
  (description "反例自检:依赖边扫描器须在 adapters 声明 postern-secrets 依赖时检出违规")
  (category security-core)
  (rationale "确保 ARCH_FORBIDDEN_EDGES 真实生效")
  (assert (gte (path db_layer forbidden_edges selftest_violation_count) 1)))
(invariant EVAL_NO_ERROR_SWALLOWING
  (severity error)
  (description "求值路径(core::eval、daemon::kernel)禁止 .ok()/.unwrap_or(true)/.unwrap_or_default() 等吞错放行写法")
  (category security-core)
  (rationale "fail-closed 是代码规范(公理二):求值路径上任何被吞掉的错误都可能变成静默放行")
  (assert (eq (path db_layer error_swallowing violation_count) 0)))
(invariant EVAL_NO_ERROR_SWALLOWING_TEETH
  (severity error)
  (description "反例自检:吞错扫描器须在求值路径出现 unwrap_or(true) 时检出违规")
  (category security-core)
  (rationale "确保 EVAL_NO_ERROR_SWALLOWING 真实生效")
  (assert (gte (path db_layer error_swallowing selftest_violation_count) 1)))
